generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @db.Uuid
  provider     Provider
  providerId   String    @unique @map("provider_id")
  name         String
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  profile              Profile?
  bodyInfo             BodyInfo[]
  userCharacter        UserCharacter?
  closetArchives       ClosetArchive[]
  posts                Post[]
  postViews            PostView[]
  postLikes            PostLike[]
  postBookmarks        PostBookmark[]
  followers            Follow[]             @relation("Following")
  following            Follow[]             @relation("Follower")
  receivedNotifications Notification[]      @relation("ReceivedNotifications")
  notificationSettings NotificationSetting?

  @@map("users")
}

model Profile {
  id        String   @id @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  nickname  String   @unique
  imageUrl  String?  @map("image_url")
  gender    Gender
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("profiles")
}

model BodyInfo {
  id           String   @id @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  height       Int
  weight       Int
  measurements Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("body_info")
}

model Character {
  id        String   @id @db.Uuid
  gender    Gender
  bodyType  BodyType @map("body_type")
  imageUrl  String   @map("image_url")

  userCharacters UserCharacter[]

  @@map("characters")
}

model UserCharacter {
  id          String          @id @db.Uuid
  userId      String          @unique @map("user_id") @db.Uuid
  characterId String?         @map("character_id") @db.Uuid
  sourceType  CharacterSource @map("source_type")
  imageUrl    String?         @map("image_url")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id])
  character Character? @relation(fields: [characterId], references: [id])

  @@map("user_character")
}

model ClosetArchive {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  imageUrl  String   @map("image_url")
  bodyInfo  Json     @map("body_info")
  modelUrl  String?  @map("model_url")
  title     String
  createdAt DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id])
  closetItems  ClosetItem[]
  post         Post?

  @@map("closet_archive")
}

model ClosetItem {
  id               String       @id @db.Uuid
  closetArchiveId  String       @map("closet_archive_id") @db.Uuid
  brand            String?
  name             String
  imageUrl         String?      @map("image_url")
  externalLink     String?      @map("external_link")
  type             ClothingType
  size             String?
  createdAt        DateTime     @default(now()) @map("created_at")

  closetArchive ClosetArchive @relation(fields: [closetArchiveId], references: [id])

  @@map("closet_items")
}

model Post {
  id               String   @id @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  closetArchiveId  String   @unique @map("closet_archive_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  user          User          @relation(fields: [userId], references: [id])
  closetArchive ClosetArchive @relation(fields: [closetArchiveId], references: [id])
  postImages    PostImage[]
  postViews     PostView[]
  postLikes     PostLike[]
  postBookmarks PostBookmark[]
  notifications Notification[]

  @@map("posts")
}

model PostImage {
  id        String   @id @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  imageUrl  String   @map("image_url")
  order     Int
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id])

  @@map("post_images")
}

model PostView {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("viewed_at")

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@map("post_views")
}

model PostLike {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("liked_at")

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("post_likes")
}

model PostBookmark {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("post_bookmarks")
}

model Follow {
  id          String   @id @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("Follower", fields: [followerId], references: [id])
  following User @relation("Following", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
  @@map("follows")
}

model Notification {
  id         String           @id @db.Uuid
  receiverId String           @map("receiver_id") @db.Uuid
  type       NotificationType
  message    String
  targetType String?          @map("target_type")
  targetId   String?          @map("target_id") @db.Uuid
  isRead     Boolean          @default(false) @map("is_read")
  createdAt  DateTime         @default(now()) @map("created_at")

  receiver User  @relation("ReceivedNotifications", fields: [receiverId], references: [id])
  post     Post? @relation(fields: [targetId], references: [id], map: "notification_post_fk")

  @@map("notifications")
}

model NotificationSetting {
  id          String   @id @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  pushEnabled Boolean  @default(true) @map("push_enabled")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notification_settings")
}

// ───────────────────────────── Enums ─────────────────────────────

enum Provider {
  GOOGLE
  KAKAO
}

enum Gender {
  MALE
  FEMALE
}

enum BodyType {
  SLIM
  NORMAL
  OVERWEIGHT
  OBESE
}

enum CharacterSource {
  CHARACTER
  UPLOAD
}

enum ClothingType {
  HAT
  OUTER
  TOP
  BOTTOM
  SHOES
}

enum NotificationType {
  FIT_2D_COMPLETE
  FIT_3D_COMPLETE
  LIKE
  FOLLOW
  FEED_FROM_FOLLOWING
}