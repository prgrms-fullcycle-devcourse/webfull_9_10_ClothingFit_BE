#!/bin/sh

commit_msg=$(cat "$1")
first_line=$(echo "$commit_msg" | head -1)

pattern="^[A-Z]+-[0-9]+ (feat|fix|docs|style|refactor|test|chore|design|comment|rename|remove|!HOTFIX) : .+"

if ! echo "$first_line" | grep -qE "$pattern"; then
  echo ""
  echo "❌ 커밋 메시지 형식이 올바르지 않습니다."
  echo ""
  echo "  올바른 형식: 지라티켓키 타입 : 커밋 제목"
  echo "  예시)  WAL-01 feat : 로그인 기능"
  echo ""
  echo "  사용 가능한 타입:"
  echo "    feat, fix, docs, style, refactor, test, chore"
  echo "    design, comment, rename, remove, !HOTFIX"
  echo ""
  exit 1
fi
